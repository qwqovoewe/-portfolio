---
// Enhanced Neko - draggable, clickable, multiple animations
---

<div id="neko-container"></div>

<script>
const NEKO_WIDTH = 38;
const NEKO_HEIGHT = 38;
const SPRITE_SIZE = 32; // Original sprite size
const NEKO_SPEED = 15;
const FRAME_RATE = 100;
const ALERT_TIME = 3;
const IDLE_THRESHOLD = 3;
const IDLE_ANIMATION_CHANCE = 1 / 20;
const MIN_DISTANCE = 10;
const SPRITE_GAP = 1;
const BACKGROUND_TARGET_COLOR: [number, number, number] = [0, 174, 240];

class Neko {
  posX: number;
  posY: number;
  initialPosX: number;
  initialPosY: number;
  mouseX: number;
  mouseY: number;
  frameCount: number;
  idleTime: number;
  idleAnimation: string | null;
  idleAnimationFrame: number;
  isFollowing: boolean;
  isReturningToOrigin: boolean;
  nekoElement: HTMLDivElement | null;
  lastFrameTimestamp: number | null;
  animationFrameId: number | null;
  spriteSets: Record<string, [number, number][]>;
  nekoImageUrl: string;
  isDragging: boolean;
  lastMouseX: number;
  lastMouseY: number;
  wasDragged: boolean;

  constructor(nekoImageUrl: string, initialPosX?: number, initialPosY?: number) {
    this.nekoImageUrl = nekoImageUrl;
    this.posX = initialPosX ?? window.innerWidth - 50;
    this.posY = initialPosY ?? window.innerHeight - 50;
    this.initialPosX = this.posX;
    this.initialPosY = this.posY;
    this.mouseX = this.posX;
    this.mouseY = this.posY;
    this.frameCount = 0;
    this.idleTime = 0;
    this.idleAnimation = null;
    this.idleAnimationFrame = 0;
    this.isFollowing = false;
    this.isReturningToOrigin = false;
    this.nekoElement = null;
    this.lastFrameTimestamp = null;
    this.animationFrameId = null;
    this.isDragging = false;
    this.wasDragged = false;
    this.lastMouseX = 0;
    this.lastMouseY = 0;

    this.spriteSets = {
      idle: [[0, 0]],
      alert: [[7, 0]],
      lickPaw: [[1, 0]],
      scratchSelf: [[2, 0], [3, 0]],
      scratchWallS: [[0, 3], [1, 3]],
      scratchWallE: [[2, 3], [3, 3]],
      scratchWallN: [[4, 3], [5, 3]],
      scratchWallW: [[6, 3], [7, 3]],
      tired: [[4, 0]],
      sleeping: [[5, 0], [6, 0]],
      S: [[0, 1], [1, 1]],
      SE: [[2, 1], [3, 1]],
      E: [[4, 1], [5, 1]],
      NE: [[6, 1], [7, 1]],
      N: [[0, 2], [1, 2]],
      NW: [[2, 2], [3, 2]],
      W: [[4, 2], [5, 2]],
      SW: [[6, 2], [7, 2]],
    };
  }

  async init() {
    await this.createNekoElement();
    this.addEventListeners();
    this.animationLoop();
  }

  async makeTransparent(imageUrl: string): Promise<string> {
    return new Promise((resolve, reject) => {
      const img = new Image();
      img.src = imageUrl;
      img.crossOrigin = "Anonymous";
      img.onload = () => {
        const canvas = document.createElement("canvas");
        const ctx = canvas.getContext("2d");
        if (!ctx) return reject("Canvas not supported");
        canvas.width = img.width;
        canvas.height = img.height;
        ctx.drawImage(img, 0, 0);
        const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
        const data = imageData.data;
        for (let i = 0; i < data.length; i += 4) {
          const r = data[i], g = data[i + 1], b = data[i + 2];
          if (r === BACKGROUND_TARGET_COLOR[0] && 
              g === BACKGROUND_TARGET_COLOR[1] && 
              b === BACKGROUND_TARGET_COLOR[2]) {
            data[i + 3] = 0;
          }
        }
        ctx.putImageData(imageData, 0, 0);
        resolve(canvas.toDataURL("image/png"));
      };
      img.onerror = reject;
    });
  }

  async createNekoElement() {
    this.nekoElement = document.createElement("div");
    this.nekoElement.id = "oneko";
    this.nekoElement.ariaHidden = "true";
    
    // Calculate scale factor
    const scale = NEKO_WIDTH / SPRITE_SIZE;
    const originalSpriteWidth = 264; // Original sprite sheet width
    const originalSpriteHeight = 198; // Original sprite sheet height
    
    this.nekoElement.style.cssText = `
      width: ${NEKO_WIDTH}px;
      height: ${NEKO_HEIGHT}px;
      position: fixed;
      pointer-events: auto;
      image-rendering: pixelated;
      z-index: 9999;
      cursor: grab;
      left: ${this.posX - NEKO_WIDTH/2}px;
      top: ${this.posY - NEKO_HEIGHT/2}px;
      background-size: ${originalSpriteWidth * scale}px ${originalSpriteHeight * scale}px;
    `;

    try {
      const transparentUrl = await this.makeTransparent(this.nekoImageUrl);
      this.nekoElement.style.backgroundImage = `url("${transparentUrl}")`;
    } catch {
      this.nekoElement.style.backgroundImage = `url("${this.nekoImageUrl}")`;
    }

    document.getElementById("neko-container")?.appendChild(this.nekoElement);
    this.setSprite("idle", 0);
  }

  setSprite(name: string, frame: number) {
    if (!this.nekoElement) return;
    const spriteSet = this.spriteSets[name];
    if (!spriteSet) return;
    const sprite = spriteSet[frame % spriteSet.length];
    if (sprite) {
      const scale = NEKO_WIDTH / SPRITE_SIZE;
      const posX = sprite[0] * (SPRITE_SIZE + SPRITE_GAP) * scale;
      const posY = sprite[1] * (SPRITE_SIZE + SPRITE_GAP) * scale;
      this.nekoElement.style.backgroundPosition = `-${posX}px -${posY}px`;
    }
  }

  addEventListeners() {
    if (!this.nekoElement) return;

    this.nekoElement.addEventListener("click", () => {
      if (!this.wasDragged) {
        this.isFollowing = !this.isFollowing;
        if (!this.isFollowing) {
          this.isReturningToOrigin = true;
        }
      }
    });

    this.nekoElement.addEventListener("mousedown", (e) => {
      this.isDragging = true;
      this.wasDragged = false;
      this.lastMouseX = e.clientX;
      this.lastMouseY = e.clientY;
      if (this.nekoElement) this.nekoElement.style.cursor = "grabbing";
      e.preventDefault();
    });

    document.addEventListener("mouseup", () => {
      this.isDragging = false;
      if (this.nekoElement) this.nekoElement.style.cursor = "grab";
    });

    document.addEventListener("mousemove", (e) => {
      if (this.isDragging) {
        const dx = e.clientX - this.lastMouseX;
        const dy = e.clientY - this.lastMouseY;
        if (Math.hypot(dx, dy) > 2) this.wasDragged = true;
        this.posX = e.clientX;
        this.posY = e.clientY;
        this.lastMouseX = e.clientX;
        this.lastMouseY = e.clientY;
        this.render();
      } else {
        this.mouseX = e.clientX;
        this.mouseY = e.clientY;
      }
    });
  }

  animationLoop() {
    const loop = (timestamp: number) => {
      if (this.lastFrameTimestamp === null) {
        this.lastFrameTimestamp = timestamp;
      }
      const delta = timestamp - this.lastFrameTimestamp;
      if (delta > FRAME_RATE) {
        this.lastFrameTimestamp = timestamp;
        this.updateState();
        this.render();
      }
      this.animationFrameId = requestAnimationFrame(loop);
    };
    this.animationFrameId = requestAnimationFrame(loop);
  }

  updateState() {
    if (this.isDragging) return;
    this.frameCount += 1;

    if (this.isReturningToOrigin) {
      this.moveToInitialPosition();
    } else if (this.isFollowing) {
      this.followMouse();
    } else {
      this.idleBehavior();
    }
  }

  render() {
    if (!this.nekoElement) return;
    this.nekoElement.style.left = `${this.posX - NEKO_WIDTH/2}px`;
    this.nekoElement.style.top = `${this.posY - NEKO_HEIGHT/2}px`;
    
    // 更新全局小猫位置，供波纹效果使用
    if (typeof window !== 'undefined') {
      window.NEKO_POSITION = { x: this.posX, y: this.posY };
    }
  }

  idleBehavior() {
    this.idleTime += 1;
    if (this.idleTime > IDLE_THRESHOLD && Math.random() < IDLE_ANIMATION_CHANCE && !this.idleAnimation) {
      const anims = ["sleeping", "scratchSelf", "lickPaw"];
      this.idleAnimation = anims[Math.floor(Math.random() * anims.length)];
    }

    switch (this.idleAnimation) {
      case "sleeping":
        if (this.idleAnimationFrame < 8) {
          this.setSprite("tired", 0);
        } else {
          this.setSprite("sleeping", Math.floor(this.idleAnimationFrame / 4));
          if (this.idleAnimationFrame > 192) this.idleAnimation = null;
        }
        break;
      case "lickPaw":
        this.setSprite("lickPaw", 0);
        if (this.idleAnimationFrame > 4) this.idleAnimation = null;
        break;
      case "scratchSelf":
        this.setSprite("scratchSelf", this.idleAnimationFrame);
        if (this.idleAnimationFrame > 9) this.idleAnimation = null;
        break;
      default:
        this.setSprite("idle", 0);
        return;
    }
    this.idleAnimationFrame += 1;
  }

  followMouse() {
    const diffX = this.posX - this.mouseX;
    const diffY = this.posY - this.mouseY;
    const distance = Math.hypot(diffX, diffY);

    if (distance < MIN_DISTANCE) {
      this.idleBehavior();
      return;
    }

    this.idleAnimation = null;
    this.idleAnimationFrame = 0;

    if (this.idleTime > 1) {
      this.setSprite("alert", 0);
      this.idleTime = Math.min(this.idleTime, ALERT_TIME) - 1;
      return;
    }

    let direction = "";
    direction += diffY / distance > 0.5 ? "N" : "";
    direction += diffY / distance < -0.5 ? "S" : "";
    direction += diffX / distance > 0.5 ? "W" : "";
    direction += diffX / distance < -0.5 ? "E" : "";
    this.setSprite(direction, this.frameCount);

    this.posX -= (diffX / distance) * NEKO_SPEED;
    this.posY -= (diffY / distance) * NEKO_SPEED;
    this.posX = Math.min(Math.max(NEKO_WIDTH/2, this.posX), window.innerWidth - NEKO_WIDTH/2);
    this.posY = Math.min(Math.max(NEKO_HEIGHT/2, this.posY), window.innerHeight - NEKO_HEIGHT/2);
  }

  moveToInitialPosition() {
    const diffX = this.posX - this.initialPosX;
    const diffY = this.posY - this.initialPosY;
    const distance = Math.hypot(diffX, diffY);

    if (distance < NEKO_SPEED) {
      this.posX = this.initialPosX;
      this.posY = this.initialPosY;
      this.isReturningToOrigin = false;
      this.idleBehavior();
      return;
    }

    let direction = "";
    direction += diffY / distance > 0.5 ? "N" : "";
    direction += diffY / distance < -0.5 ? "S" : "";
    direction += diffX / distance > 0.5 ? "W" : "";
    direction += diffX / distance < -0.5 ? "E" : "";
    this.setSprite(direction, this.frameCount);

    this.posX -= (diffX / distance) * NEKO_SPEED;
    this.posY -= (diffY / distance) * NEKO_SPEED;
  }
}

// Initialize
const base = import.meta.env.BASE_URL;
const neko = new Neko(`${base}/neko-orange.png`);
neko.init();
</script>
