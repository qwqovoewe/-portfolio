---
// Custom pixel cat - follows cursor
---

<div id="oneko-container"></div>

<script>
(function cat() {
    const catEl = document.createElement("div");
    let catPosX = window.innerWidth / 2;
    let catPosY = window.innerHeight / 2;
    let mousePosX = catPosX;
    let mousePosY = catPosY;
    
    const speed = 8;
    const catWidth = 64;
    const catHeight = 48;

    function create() {
        catEl.id = "custom-cat";
        catEl.style.cssText = `
            position: fixed;
            width: ${catWidth}px;
            height: ${catHeight}px;
            pointer-events: none;
            z-index: 9999;
            background-image: url('/portfolio/orange-cat.png');
            background-size: contain;
            background-repeat: no-repeat;
            image-rendering: pixelated;
            left: ${catPosX - catWidth/2}px;
            top: ${catPosY - catHeight/2}px;
            transition: transform 0.1s ease-out;
        `;
        document.body.appendChild(catEl);

        document.addEventListener("mousemove", (event) => {
            mousePosX = event.clientX;
            mousePosY = event.clientY;
        });

        // Double click to teleport
        document.addEventListener("dblclick", (event) => {
            catPosX = event.clientX;
            catPosY = event.clientY;
            catEl.style.left = `${catPosX - catWidth/2}px`;
            catEl.style.top = `${catPosY - catHeight/2}px`;
        });

        setInterval(frame, 16); // ~60fps
    }

    function frame() {
        const diffX = catPosX - mousePosX;
        const diffY = catPosY - mousePosY;
        const distance = Math.sqrt(diffX ** 2 + diffY ** 2);

        if (distance < 5) return; // Close enough

        // Move towards mouse
        catPosX -= (diffX / distance) * speed;
        catPosY -= (diffY / distance) * speed;

        // Keep in bounds
        catPosX = Math.min(Math.max(catWidth/2, catPosX), window.innerWidth - catWidth/2);
        catPosY = Math.min(Math.max(catHeight/2, catPosY), window.innerHeight - catHeight/2);

        // Flip cat based on direction
        const scaleX = diffX > 0 ? 1 : -1;
        catEl.style.transform = `scaleX(${scaleX})`;

        catEl.style.left = `${catPosX - catWidth/2}px`;
        catEl.style.top = `${catPosY - catHeight/2}px`;
    }

    create();
})();
</script>
