---
// Oneko - Classic cat cursor follower
---

<div id="oneko-container" class="fixed pointer-events-none z-50"></div>

<script>
  // Oneko implementation - classic Japanese cat cursor follower
  const nekoEl = document.createElement('div');
  nekoEl.id = 'oneko';
  nekoEl.style.cssText = `
    position: fixed;
    width: 32px;
    height: 32px;
    pointer-events: none;
    image-rendering: pixelated;
    z-index: 9999;
  `;
  document.getElementById('oneko-container')?.appendChild(nekoEl);

  // Sprite sheet (embedded as data URL - classic oneko sprite)
  const spriteUrl = 'https://raw.githubusercontent.com/adryd325/oneko.js/main/oneko.gif';
  
  nekoEl.style.backgroundImage = `url(${spriteUrl})`;

  // Cat state
  let nekoPosX = window.innerWidth / 2;
  let nekoPosY = window.innerHeight / 2;
  let mousePosX = nekoPosX;
  let mousePosY = nekoPosY;
  let frameCount = 0;
  let idleTime = 0;
  let idleAnimation: string | null = null;
  let idleAnimationFrame = 0;

  const speed = 10;
  const spriteSets = {
    idle: [[-3, -3]],
    alert: [[-7, -3]],
    scratchSelf: [
      [-5, 0], [-6, 0], [-7, 0],
    ],
    scratchWallN: [
      [0, 0], [0, -1],
    ],
    scratchWallS: [
      [-7, -1], [-6, -1],
    ],
    scratchWallE: [
      [-2, -2], [-2, -3],
    ],
    scratchWallW: [
      [-4, 0], [-4, -1],
    ],
    tired: [[-3, -2]],
    sleeping: [
      [-2, 0], [-2, -1],
    ],
    N: [
      [-1, -2], [-1, -3],
    ],
    NE: [
      [1, -2], [1, -3],
    ],
    E: [
      [2, -2], [2, -3],
    ],
    SE: [
      [2, 0], [2, -1],
    ],
    S: [
      [-1, 0], [-1, -1],
    ],
    SW: [
      [-3, 0], [-3, -1],
    ],
    W: [
      [-4, -2], [-4, -3],
    ],
    NW: [
      [-3, -2], [-3, -3],
    ],
  };

  function setSprite(name: string, frame: number) {
    const sprite = spriteSets[name as keyof typeof spriteSets][frame % spriteSets[name as keyof typeof spriteSets].length];
    nekoEl.style.backgroundPosition = `${sprite[0] * 32}px ${sprite[1] * 32}px`;
  }

  function resetIdleAnimation() {
    idleAnimation = null;
    idleAnimationFrame = 0;
  }

  function idle() {
    idleTime += 1;

    // every ~ 20 seconds
    if ((idleTime % 600) === 0 && Math.random() < 0.1) {
      const availableIdleAnimations = ['sleeping', 'scratchSelf'];
      idleAnimation = availableIdleAnimations[Math.floor(Math.random() * availableIdleAnimations.length)];
    }

    if (idleAnimation) {
      setSprite(idleAnimation, idleAnimationFrame);
      idleAnimationFrame += 1;
      if (idleAnimationFrame >= spriteSets[idleAnimation as keyof typeof spriteSets].length) {
        if (idleAnimation === 'sleeping' && Math.random() < 0.5) {
          // keep sleeping
          idleAnimationFrame = 0;
        } else {
          resetIdleAnimation();
        }
      }
    } else {
      setSprite('idle', 0);
    }
  }

  function frame() {
    frameCount += 1;

    const diffX = nekoPosX - mousePosX;
    const diffY = nekoPosY - mousePosY;
    const distance = Math.sqrt(diffX ** 2 + diffY ** 2);

    if (distance < speed || (distance < 48 && Math.abs(diffX) < 16 && Math.abs(diffY) < 16)) {
      idle();
      return;
    }

    idleAnimation = null;
    idleAnimationFrame = 0;

    if (idleTime > 1) {
      setSprite('alert', 0);
      idleTime = Math.max(idleTime - 8, 0);
      return;
    }

    let direction: string;
    direction = diffY / distance > 0.5 ? 'N' : diffY / distance < -0.5 ? 'S' : '';
    direction += diffX / distance > 0.5 ? 'W' : diffX / distance < -0.5 ? 'E' : '';

    setSprite(direction, frameCount);

    nekoPosX -= (diffX / distance) * speed;
    nekoPosY -= (diffY / distance) * speed;

    nekoPosX = Math.min(Math.max(16, nekoPosX), window.innerWidth - 16);
    nekoPosY = Math.min(Math.max(16, nekoPosY), window.innerHeight - 16);

    nekoEl.style.left = `${nekoPosX - 16}px`;
    nekoEl.style.top = `${nekoPosY - 16}px`;
  }

  document.addEventListener('mousemove', (event) => {
    mousePosX = event.clientX;
    mousePosY = event.clientY;
  });

  // Double click to summon cat
  document.addEventListener('dblclick', (event) => {
    nekoPosX = event.clientX;
    nekoPosY = event.clientY;
  });

  // Start position
  nekoEl.style.left = `${nekoPosX - 16}px`;
  nekoEl.style.top = `${nekoPosY - 16}px`;

  setInterval(frame, 100);
</script>
