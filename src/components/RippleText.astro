---
// RippleText - 文字波纹效果组件 + 名字粒子入场动画
---

<canvas id="ripple-canvas" class="fixed inset-0 w-full h-full pointer-events-none" style="z-index: 0;"></canvas>

<script>
// 全局小猫位置共享
declare global {
  interface Window {
    NEKO_POSITION: { x: number; y: number };
    MOUSE_POSITION: { x: number; y: number };
  }
}

window.NEKO_POSITION = { x: -9999, y: -9999 };
window.MOUSE_POSITION = { x: -9999, y: -9999 };

// 追踪鼠标位置
document.addEventListener('mousemove', (e) => {
  window.MOUSE_POSITION = { x: e.clientX, y: e.clientY };
});

// Canvas 波纹粒子系统
const canvas = document.getElementById('ripple-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;

let width = 0, height = 0;
const dpr = window.devicePixelRatio || 1;

// ============ 入场动画状态 ============
const PHASE_ASSEMBLE = 0;   // 粒子飞入聚合
const PHASE_DISSOLVE = 1;   // 粒子消散
const PHASE_DONE = 2;       // 入场结束

let animPhase = PHASE_ASSEMBLE;
let animStartTime = performance.now();
const ASSEMBLE_DURATION = 2000;  // 聚合持续 2s
const DISSOLVE_DURATION = 1000;  // 消散持续 1s
let heroRevealed = false;

// ============ 名字粒子（入场动画） ============
class FormParticle {
  targetX: number;
  targetY: number;
  x: number;
  y: number;
  vx: number = 0;
  vy: number = 0;
  alpha: number;
  radius: number;
  opacity: number = 1; // 消散时用

  constructor(targetX: number, targetY: number, alpha: number) {
    this.targetX = targetX;
    this.targetY = targetY;
    this.alpha = alpha;
    this.radius = 1.2 + Math.random() * 1;
    // 从随机位置出发
    const angle = Math.random() * Math.PI * 2;
    const dist = 300 + Math.random() * 500;
    this.x = targetX + Math.cos(angle) * dist;
    this.y = targetY + Math.sin(angle) * dist;
  }

  update(mouseX: number, mouseY: number) {
    // 线性插值趋近目标
    this.x += (this.targetX - this.x) * 0.05;
    this.y += (this.targetY - this.y) * 0.05;

    // 鼠标排斥（搅动效果）
    const dx = this.x - mouseX;
    const dy = this.y - mouseY;
    const dist = Math.sqrt(dx * dx + dy * dy);
    if (dist < 100 && dist > 0) {
      const f = (100 - dist) / 100;
      const a = Math.atan2(dy, dx);
      this.x += Math.cos(a) * f * 8;
      this.y += Math.sin(a) * f * 8;
    }
  }

  draw(ctx: CanvasRenderingContext2D) {
    ctx.globalAlpha = this.alpha * this.opacity;
    ctx.beginPath();
    ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
    ctx.fill();
  }
}

// ============ 网格点粒子（保持原有） ============
class DotParticle {
  x: number;
  y: number;
  originX: number;
  originY: number;
  vx: number = 0;
  vy: number = 0;

  constructor(x: number, y: number) {
    this.x = x;
    this.y = y;
    this.originX = x;
    this.originY = y;
  }

  update(nekoX: number, nekoY: number, mouseX: number, mouseY: number) {
    const dxNeko = this.x - nekoX;
    const dyNeko = this.y - nekoY;
    const distNeko = Math.sqrt(dxNeko * dxNeko + dyNeko * dyNeko);
    const nekoRadius = 80;

    if (distNeko < nekoRadius) {
      const force = (nekoRadius - distNeko) / nekoRadius;
      const angle = Math.atan2(dyNeko, dxNeko);
      this.vx += Math.cos(angle) * force * 1.5;
      this.vy += Math.sin(angle) * force * 1.5;
    }

    const dxMouse = this.x - mouseX;
    const dyMouse = this.y - mouseY;
    const distMouse = Math.sqrt(dxMouse * dxMouse + dyMouse * dyMouse);
    const mouseRadius = 60;

    if (distMouse < mouseRadius) {
      const force = (mouseRadius - distMouse) / mouseRadius;
      const angle = Math.atan2(dyMouse, dxMouse);
      this.vx += Math.cos(angle) * force * 1;
      this.vy += Math.sin(angle) * force * 1;
    }

    this.vx += (this.originX - this.x) * 0.05;
    this.vy += (this.originY - this.y) * 0.05;

    this.vx *= 0.9;
    this.vy *= 0.9;

    this.x += this.vx;
    this.y += this.vy;
  }

  draw(ctx: CanvasRenderingContext2D) {
    ctx.beginPath();
    ctx.arc(this.x, this.y, 1.5, 0, Math.PI * 2);
    ctx.fill();
  }
}

// ============ 漂浮关键词粒子 ============
class TextParticle {
  text: string;
  x: number;
  y: number;
  originX: number;
  originY: number;
  vx: number = 0;
  vy: number = 0;
  fontSize: number;
  opacity: number;
  color: string;
  time: number;
  driftPhase: number;
  opacityPhase: number;
  driftSpeed: number;

  constructor(text: string, x: number, y: number) {
    this.text = text;
    this.x = x;
    this.y = y;
    this.originX = x;
    this.originY = y;
    this.fontSize = 12 + Math.random() * 16;
    this.opacity = 0.12 + Math.random() * 0.18;
    this.color = `rgba(129, 140, 248, ${this.opacity})`;
    this.time = Math.random() * Math.PI * 2;
    this.driftPhase = Math.random() * Math.PI * 2;
    this.opacityPhase = Math.random() * Math.PI * 2;
    this.driftSpeed = 0.004 + Math.random() * 0.003;
  }

  update(nekoX: number, nekoY: number, mouseX: number, mouseY: number) {
    this.time += this.driftSpeed;
    const driftAmp = 4;
    const driftTargetX = this.originX + Math.sin(this.time * 0.9 + this.driftPhase) * driftAmp;
    const driftTargetY = this.originY + Math.cos(this.time * 0.7 + this.driftPhase * 1.3) * driftAmp;

    const dxNeko = this.x - nekoX;
    const dyNeko = this.y - nekoY;
    const distNeko = Math.sqrt(dxNeko * dxNeko + dyNeko * dyNeko);
    const dxMouse = this.x - mouseX;
    const dyMouse = this.y - mouseY;
    const distMouse = Math.sqrt(dxMouse * dxMouse + dyMouse * dyMouse);

    if (distNeko < 120) {
      const force = (120 - distNeko) / 120;
      const angle = Math.atan2(dyNeko, dxNeko);
      this.vx += Math.cos(angle) * force * 2;
      this.vy += Math.sin(angle) * force * 2;
    }
    if (distMouse < 80) {
      const force = (80 - distMouse) / 80;
      const angle = Math.atan2(dyMouse, dxMouse);
      this.vx += Math.cos(angle) * force * 1.2;
      this.vy += Math.sin(angle) * force * 1.2;
    }

    this.vx += (driftTargetX - this.x) * 0.02;
    this.vy += (driftTargetY - this.y) * 0.02;
    this.vx *= 0.92;
    this.vy *= 0.92;
    this.x += this.vx;
    this.y += this.vy;
  }

  draw(ctx: CanvasRenderingContext2D) {
    const breathe = Math.sin(this.time * 1.2 + this.opacityPhase) * 0.05;
    const baseOpacity = Math.max(0, this.opacity + breathe);
    const speed = Math.sqrt(this.vx * this.vx + this.vy * this.vy);
    const dynamicOpacity = Math.min(baseOpacity + speed * 0.03, 0.6);
    ctx.globalAlpha = dynamicOpacity;
    ctx.font = `${this.fontSize}px "Inter", system-ui, sans-serif`;
    ctx.fillStyle = '#818cf8';
    ctx.fillText(this.text, this.x, this.y);
  }
}

// ============ 像素采样 ============
function sampleTextPixels(text: string, fontSize: number, centerX: number, centerY: number): FormParticle[] {
  const offscreen = document.createElement('canvas');
  const offCtx = offscreen.getContext('2d')!;

  // 设置字体并测量
  offCtx.font = `bold ${fontSize}px "Inter", system-ui, sans-serif`;
  const metrics = offCtx.measureText(text);
  const textWidth = metrics.width;
  const textHeight = fontSize * 1.2;

  // 离屏画布大小（留边距）
  const pad = 10;
  offscreen.width = Math.ceil(textWidth) + pad * 2;
  offscreen.height = Math.ceil(textHeight) + pad * 2;

  // 重新设置字体（canvas resize 后会重置）
  offCtx.font = `bold ${fontSize}px "Inter", system-ui, sans-serif`;
  offCtx.fillStyle = '#ffffff';
  offCtx.textBaseline = 'top';
  offCtx.fillText(text, pad, pad + (textHeight - fontSize) / 2);

  // 采样像素
  const imageData = offCtx.getImageData(0, 0, offscreen.width, offscreen.height);
  const data = imageData.data;
  const particles: FormParticle[] = [];
  const step = 3; // 每 3 像素采样一个

  // 文字在主 canvas 上的偏移（居中）
  const offsetX = centerX - textWidth / 2;
  const offsetY = centerY - textHeight / 2;

  for (let y = 0; y < offscreen.height; y += step) {
    for (let x = 0; x < offscreen.width; x += step) {
      const i = (y * offscreen.width + x) * 4;
      const a = data[i + 3]; // alpha
      if (a > 50) {
        const px = offsetX + x - pad;
        const py = offsetY + y - pad;
        const normalAlpha = 0.4 + (a / 255) * 0.6; // 映射到 0.4-1.0
        particles.push(new FormParticle(px, py, normalAlpha));
      }
    }
  }

  return particles;
}

// ============ 像素采样（仅坐标） ============
function sampleTargets(text: string, fontSize: number, centerX: number, centerY: number, step: number): {x: number, y: number, a: number}[] {
  const offscreen = document.createElement('canvas');
  const offCtx = offscreen.getContext('2d')!;

  offCtx.font = `bold ${fontSize}px "Inter", system-ui, sans-serif`;
  const metrics = offCtx.measureText(text);
  const textWidth = metrics.width;
  const textHeight = fontSize * 1.2;

  const pad = 10;
  offscreen.width = Math.ceil(textWidth) + pad * 2;
  offscreen.height = Math.ceil(textHeight) + pad * 2;

  offCtx.font = `bold ${fontSize}px "Inter", system-ui, sans-serif`;
  offCtx.fillStyle = '#ffffff';
  offCtx.textBaseline = 'top';
  offCtx.fillText(text, pad, pad + (textHeight - fontSize) / 2);

  const imageData = offCtx.getImageData(0, 0, offscreen.width, offscreen.height);
  const data = imageData.data;
  const targets: {x: number, y: number, a: number}[] = [];

  const offsetX = centerX - textWidth / 2;
  const offsetY = centerY - textHeight / 2;

  for (let y = 0; y < offscreen.height; y += step) {
    for (let x = 0; x < offscreen.width; x += step) {
      const i = (y * offscreen.width + x) * 4;
      const alpha = data[i + 3];
      if (alpha > 50) {
        targets.push({
          x: offsetX + x - pad,
          y: offsetY + y - pad,
          a: 0.6 + (alpha / 255) * 0.4,
        });
      }
    }
  }
  return targets;
}

// ============ Morph 粒子 ============
class MorphParticle {
  x: number;
  y: number;
  radius: number;
  alpha: number;
  allTargets: {x: number, y: number, a: number}[]; // 当前 from 目标在 index 0，其他依次排列
  fromX: number;
  fromY: number;
  fromA: number;

  constructor(target: {x: number, y: number, a: number}) {
    this.x = target.x;
    this.y = target.y;
    this.alpha = target.a;
    this.radius = 1.0 + Math.random() * 0.8;
    this.allTargets = [];
    this.fromX = target.x;
    this.fromY = target.y;
    this.fromA = target.a;
  }

  update(toIdx: number, progress: number, mouseX: number, mouseY: number) {
    const to = this.allTargets[toIdx];
    if (!to) return;

    // smoothstep 插值
    const t = progress < 1 ? progress * progress * (3 - 2 * progress) : 1;
    this.x = this.fromX + (to.x - this.fromX) * t;
    this.y = this.fromY + (to.y - this.fromY) * t;
    this.alpha = this.fromA + (to.a - this.fromA) * t;

    // 鼠标排斥
    const dx = this.x - mouseX;
    const dy = this.y - mouseY;
    const dist = Math.sqrt(dx * dx + dy * dy);
    if (dist < 100 && dist > 0) {
      const f = (100 - dist) / 100;
      const a = Math.atan2(dy, dx);
      this.x += Math.cos(a) * f * 8;
      this.y += Math.sin(a) * f * 8;
    }
  }

  snapTo(idx: number) {
    const t = this.allTargets[idx];
    if (!t) return;
    this.fromX = t.x;
    this.fromY = t.y;
    this.fromA = t.a;
    this.x = t.x;
    this.y = t.y;
    this.alpha = t.a;
  }

  draw(ctx: CanvasRenderingContext2D) {
    if (this.alpha < 0.01) return;
    ctx.globalAlpha = this.alpha;
    ctx.beginPath();
    ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
    ctx.fill();
  }
}

// ============ 粒子数组 ============
let formParticles: FormParticle[] = [];
const dotParticles: DotParticle[] = [];
const textParticles: TextParticle[] = [];
let morphParticles: MorphParticle[] = [];

// ============ Morph 状态 ============
const morphTexts = ['Java Developer', 'Backend Engineer', 'AI Explorer'];
const MORPH_HOLD = 1500;      // 停留 1.5s
const MORPH_TRANSITION = 1500; // 过渡 1.5s
const MORPH_CYCLE = MORPH_HOLD + MORPH_TRANSITION;
let morphCurrentIdx = 0;
let morphStartTime = 0;
let morphActive = false;
let morphLastCycle = -1; // 上一个周期编号

const phrases = [
  'JVM', 'AQS', 'CAS', 'MVCC', 'Binlog', 'NIO', 'pprof', 'LZ4', 'gRPC',
  'LLM', 'RAG', 'Embedding', 'Prompt', 'Transformer', 'Token', 'Fine-tune', 'Vector', 'Attention', 'RLHF',
  'O(log n)', '// TODO', '0xCAFE', 'null', '42', 'NaN',
];


// ============ 二进制代码雨 + 彩蛋 ============
const rainFontSize = 14;
const rainFont = `${rainFontSize}px "Courier New", "SF Mono", monospace`;
const rainCharH = 18;
const easterEggs = [':)', ':D', '^_^', '<3', ';)', 'XD', 'ERROR', '404', 'NULL', 'BUG', 'OOPS', 'HELP', 'CAFE', '0xFF'];

interface RainColumn {
  x: number;
  chars: string[];     // 每行的字符
  head: number;        // 头部行索引
  length: number;      // 尾巴长度
  speed: number;       // 每帧前进概率
  eggRow: number;      // 彩蛋所在行（-1 表示无）
  eggText: string;     // 彩蛋文字
}

const rainColumns: RainColumn[] = [];

function initCodeRain() {
  rainColumns.length = 0;
  const colSpacing = rainFontSize + 4;
  const cols = Math.floor(width / colSpacing);
  const rows = Math.ceil(height / rainCharH) + 2;

  for (let i = 0; i < cols; i++) {
    const chars: string[] = [];
    for (let j = 0; j < rows; j++) {
      chars.push(Math.random() < 0.5 ? '0' : '1');
    }

    // ~5% 的列带彩蛋
    const hasEgg = Math.random() < 0.05;

    rainColumns.push({
      x: i * colSpacing + colSpacing / 2,
      chars,
      head: Math.floor(Math.random() * rows),
      length: 8 + Math.floor(Math.random() * 16),
      speed: 0.02 + Math.random() * 0.04,
      eggRow: hasEgg ? Math.floor(Math.random() * rows) : -1,
      eggText: easterEggs[Math.floor(Math.random() * easterEggs.length)],
    });
  }
}

function drawCodeRain(ctx: CanvasRenderingContext2D) {
  ctx.font = rainFont;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'top';

  const rows = rainColumns[0]?.chars.length || 0;

  for (const col of rainColumns) {
    if (Math.random() < col.speed) {
      col.head = (col.head + 1) % rows;
      // 头部经过时刷新字符
      col.chars[col.head] = Math.random() < 0.5 ? '0' : '1';
      // 小概率刷新彩蛋
      if (Math.random() < 0.003) {
        col.eggRow = col.head;
        col.eggText = easterEggs[Math.floor(Math.random() * easterEggs.length)];
      }
    }

    for (let t = 0; t < col.length; t++) {
      const rowIdx = (col.head - t + rows) % rows;
      const y = rowIdx * rainCharH;
      if (y < -rainCharH || y > height) continue;

      const fade = 1 - t / col.length;

      // 是否是彩蛋行
      if (rowIdx === col.eggRow && t < col.length * 0.7) {
        ctx.fillStyle = '#c4b5fd'; // 紫色高亮
        ctx.globalAlpha = Math.min(fade * 0.35, 0.35);
        ctx.fillText(col.eggText, col.x, y);
        continue;
      }

      if (t === 0) {
        ctx.fillStyle = '#a5b4fc';
        ctx.globalAlpha = 0.3;
      } else {
        ctx.fillStyle = '#818cf8';
        ctx.globalAlpha = fade * 0.15;
      }

      if (ctx.globalAlpha < 0.01) continue;
      ctx.fillText(col.chars[rowIdx], col.x, y);
    }
  }

  ctx.textAlign = 'start';
}


function resize() {
  width = window.innerWidth;
  height = window.innerHeight;
  canvas.width = width * dpr;
  canvas.height = height * dpr;
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  initCodeRain();
  initParticles();
}

function initParticles() {
  dotParticles.length = 0;
  textParticles.length = 0;

  // 漂浮关键词粒子
  const textCount = Math.min(Math.floor((width * height) / 25000), 40);
  for (let i = 0; i < textCount; i++) {
    const text = phrases[Math.floor(Math.random() * phrases.length)];
    textParticles.push(new TextParticle(text, Math.random() * width, Math.random() * height));
  }

  // 网格点粒子
  const spacing = 50;
  for (let x = spacing; x < width; x += spacing) {
    for (let y = spacing; y < height; y += spacing) {
      dotParticles.push(new DotParticle(x, y));
    }
  }

  // 名字粒子（只在入场动画阶段初始化）
  if (animPhase !== PHASE_DONE) {
    const fontSize = width < 768 ? 48 : 80;
    const centerX = width / 2;
    const centerY = height * 0.38;
    formParticles = sampleTextPixels('Ruixuan Wang', fontSize, centerX, centerY);
    // 重置动画
    animStartTime = performance.now();
    animPhase = PHASE_ASSEMBLE;
    heroRevealed = false;
  }

  // Morph 粒子初始化（采样所有文字）
  const morphFontSize = width < 768 ? 22 : 32;
  const morphCenterX = width / 2;
  const morphCenterY = 64 + morphFontSize + 20; // 导航栏(64px)下方居中
  const step = 2;

  const allTargets = morphTexts.map(t => sampleTargets(t, morphFontSize, morphCenterX, morphCenterY, step));
  const maxCount = Math.max(...allTargets.map(t => t.length));

  // 填充不足的文字目标（淡出到中心，alpha=0）
  for (const targets of allTargets) {
    while (targets.length < maxCount) {
      targets.push({ x: morphCenterX, y: morphCenterY, a: 0 });
    }
  }

  morphParticles = [];
  for (let i = 0; i < maxCount; i++) {
    const p = new MorphParticle(allTargets[0][i]);
    p.allTargets = allTargets.map(t => t[i]);
    morphParticles.push(p);
  }
  morphCurrentIdx = 0;
  morphStartTime = performance.now();
  morphActive = false;
}

function animate() {
  ctx.clearRect(0, 0, width, height);

  const now = performance.now();
  const elapsed = now - animStartTime;
  const nekoPos = window.NEKO_POSITION || { x: width / 2, y: height / 2 };
  const mousePos = window.MOUSE_POSITION || { x: width / 2, y: height / 2 };

  // ---- 入场动画状态机 ----
  if (animPhase === PHASE_ASSEMBLE && elapsed >= ASSEMBLE_DURATION) {
    animPhase = PHASE_DISSOLVE;
    // 通知 HTML 标题淡入
    if (!heroRevealed) {
      heroRevealed = true;
      window.dispatchEvent(new CustomEvent('hero-text-reveal'));
    }
  }
  if (animPhase === PHASE_DISSOLVE && elapsed >= ASSEMBLE_DURATION + DISSOLVE_DURATION) {
    animPhase = PHASE_DONE;
    formParticles.length = 0; // 释放内存
    // 启动 Morph 动画
    if (!morphActive) {
      morphActive = true;
      morphStartTime = now;
      morphCurrentIdx = 0;
      morphLastCycle = 0;
    }
  }

  // ---- 绘制代码雨 ----
  drawCodeRain(ctx);

  // ---- 绘制网格点 ----
  ctx.globalAlpha = 0.08;
  ctx.fillStyle = '#818cf8';
  for (const dot of dotParticles) {
    dot.update(nekoPos.x, nekoPos.y, mousePos.x, mousePos.y);
    dot.draw(ctx);
  }

  // ---- 绘制漂浮关键词 ----
  for (const particle of textParticles) {
    particle.update(nekoPos.x, nekoPos.y, mousePos.x, mousePos.y);
    particle.draw(ctx);
  }

  // ---- 绘制名字粒子 ----
  if (animPhase !== PHASE_DONE) {
    ctx.fillStyle = '#818cf8';
    // 消散阶段逐渐降低透明度
    if (animPhase === PHASE_DISSOLVE) {
      const dissolveProgress = (elapsed - ASSEMBLE_DURATION) / DISSOLVE_DURATION;
      for (const p of formParticles) {
        p.opacity = 1 - dissolveProgress;
      }
    }
    for (const p of formParticles) {
      p.update(mousePos.x, mousePos.y);
      p.draw(ctx);
    }
  }

  // ---- 绘制 Morph 粒子 ----
  if (morphActive && morphParticles.length > 0) {
    ctx.fillStyle = '#818cf8';
    const morphElapsed = now - morphStartTime;

    // 先检测是否需要切换到下一段
    const currCycle = Math.floor(morphElapsed / MORPH_CYCLE);
    if (currCycle > morphLastCycle && morphLastCycle >= 0) {
      morphCurrentIdx = (morphCurrentIdx + 1) % morphTexts.length;
      for (const p of morphParticles) {
        p.snapTo(morphCurrentIdx);
      }
    }
    morphLastCycle = currCycle;

    const cycleTime = morphElapsed % MORPH_CYCLE;
    const nextIdx = (morphCurrentIdx + 1) % morphTexts.length;

    if (cycleTime < MORPH_HOLD) {
      for (const p of morphParticles) {
        p.update(morphCurrentIdx, 1, mousePos.x, mousePos.y);
        p.draw(ctx);
      }
    } else {
      const progress = (cycleTime - MORPH_HOLD) / MORPH_TRANSITION;
      for (const p of morphParticles) {
        p.update(nextIdx, progress, mousePos.x, mousePos.y);
        p.draw(ctx);
      }
    }
  }

  ctx.globalAlpha = 1;
  requestAnimationFrame(animate);
}

// 初始化
resize();
animate();
window.addEventListener('resize', resize);
</script>

