---
// RippleText - 文字波纹效果组件
// 小猫追逐鼠标时，文字粒子像水一样散开
---

<canvas id="ripple-canvas" class="fixed inset-0 w-full h-full pointer-events-none" style="z-index: 0;"></canvas>

<script>
// 全局小猫位置共享
declare global {
  interface Window {
    NEKO_POSITION: { x: number; y: number };
    MOUSE_POSITION: { x: number; y: number };
  }
}

window.NEKO_POSITION = { x: window.innerWidth / 2, y: window.innerHeight / 2 };
window.MOUSE_POSITION = { x: window.innerWidth / 2, y: window.innerHeight / 2 };

// 追踪鼠标位置
document.addEventListener('mousemove', (e) => {
  window.MOUSE_POSITION = { x: e.clientX, y: e.clientY };
});

// Canvas 波纹粒子系统
const canvas = document.getElementById('ripple-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;

let width = 0, height = 0;
const dpr = window.devicePixelRatio || 1;

// 粒子类
class TextParticle {
  text: string;
  x: number;
  y: number;
  originX: number;
  originY: number;
  vx: number = 0;
  vy: number = 0;
  fontSize: number;
  opacity: number;
  color: string;
  // 独立动画相位（随机，避免粒子同步晃动）
  time: number;
  driftPhase: number;
  opacityPhase: number;
  // 漂移速率（每粒子略有不同）
  driftSpeed: number;

  constructor(text: string, x: number, y: number) {
    this.text = text;
    this.x = x;
    this.y = y;
    this.originX = x;
    this.originY = y;
    this.fontSize = 12 + Math.random() * 16;
    this.opacity = 0.12 + Math.random() * 0.18;
    this.color = `rgba(129, 140, 248, ${this.opacity})`;
    // 随机初始相位，让每个粒子独立运动
    this.time = Math.random() * Math.PI * 2;
    this.driftPhase = Math.random() * Math.PI * 2;
    this.opacityPhase = Math.random() * Math.PI * 2;
    this.driftSpeed = 0.004 + Math.random() * 0.003; // 慢速漂移
  }

  update(nekoX: number, nekoY: number, mouseX: number, mouseY: number) {
    // 推进个人时钟
    this.time += this.driftSpeed;

    // 静止时的慢速飘动：让弹簧目标点缓慢游走
    const driftAmp = 4;
    const driftTargetX = this.originX + Math.sin(this.time * 0.9 + this.driftPhase) * driftAmp;
    const driftTargetY = this.originY + Math.cos(this.time * 0.7 + this.driftPhase * 1.3) * driftAmp;

    // 计算与小猫的距离
    const dxNeko = this.x - nekoX;
    const dyNeko = this.y - nekoY;
    const distNeko = Math.sqrt(dxNeko * dxNeko + dyNeko * dyNeko);

    // 计算与鼠标的距离
    const dxMouse = this.x - mouseX;
    const dyMouse = this.y - mouseY;
    const distMouse = Math.sqrt(dxMouse * dxMouse + dyMouse * dyMouse);

    // 小猫影响半径（更大）
    const nekoRadius = 120;
    // 鼠标影响半径（稍小）
    const mouseRadius = 80;

    // 小猫推力
    if (distNeko < nekoRadius) {
      const force = (nekoRadius - distNeko) / nekoRadius;
      const angle = Math.atan2(dyNeko, dxNeko);
      this.vx += Math.cos(angle) * force * 2;
      this.vy += Math.sin(angle) * force * 2;
    }

    // 鼠标推力（较弱）
    if (distMouse < mouseRadius) {
      const force = (mouseRadius - distMouse) / mouseRadius;
      const angle = Math.atan2(dyMouse, dxMouse);
      this.vx += Math.cos(angle) * force * 1.2;
      this.vy += Math.sin(angle) * force * 1.2;
    }

    // 弹簧力 - 回到漂移目标点（而非固定原点）
    const springK = 0.02;
    this.vx += (driftTargetX - this.x) * springK;
    this.vy += (driftTargetY - this.y) * springK;

    // 阻尼
    this.vx *= 0.92;
    this.vy *= 0.92;

    // 更新位置
    this.x += this.vx;
    this.y += this.vy;
  }

  draw(ctx: CanvasRenderingContext2D) {
    // 呼吸式忽明忽暗（振幅小，频率慢）
    const breathe = Math.sin(this.time * 1.2 + this.opacityPhase) * 0.05;
    const baseOpacity = Math.max(0, this.opacity + breathe);
    // 被交互时额外提亮
    const speed = Math.sqrt(this.vx * this.vx + this.vy * this.vy);
    const dynamicOpacity = Math.min(baseOpacity + speed * 0.03, 0.6);

    ctx.globalAlpha = dynamicOpacity;
    ctx.font = `${this.fontSize}px "Inter", system-ui, sans-serif`;
    ctx.fillStyle = '#818cf8';
    ctx.fillText(this.text, this.x, this.y);
  }
}

// 网格点粒子类
class DotParticle {
  x: number;
  y: number;
  originX: number;
  originY: number;
  vx: number = 0;
  vy: number = 0;
  
  constructor(x: number, y: number) {
    this.x = x;
    this.y = y;
    this.originX = x;
    this.originY = y;
  }
  
  update(nekoX: number, nekoY: number, mouseX: number, mouseY: number) {
    // 小猫影响
    const dxNeko = this.x - nekoX;
    const dyNeko = this.y - nekoY;
    const distNeko = Math.sqrt(dxNeko * dxNeko + dyNeko * dyNeko);
    const nekoRadius = 80;
    
    if (distNeko < nekoRadius) {
      const force = (nekoRadius - distNeko) / nekoRadius;
      const angle = Math.atan2(dyNeko, dxNeko);
      this.vx += Math.cos(angle) * force * 1.5;
      this.vy += Math.sin(angle) * force * 1.5;
    }
    
    // 鼠标影响
    const dxMouse = this.x - mouseX;
    const dyMouse = this.y - mouseY;
    const distMouse = Math.sqrt(dxMouse * dxMouse + dyMouse * dyMouse);
    const mouseRadius = 60;
    
    if (distMouse < mouseRadius) {
      const force = (mouseRadius - distMouse) / mouseRadius;
      const angle = Math.atan2(dyMouse, dxMouse);
      this.vx += Math.cos(angle) * force * 1;
      this.vy += Math.sin(angle) * force * 1;
    }
    
    // 弹簧力
    this.vx += (this.originX - this.x) * 0.05;
    this.vy += (this.originY - this.y) * 0.05;
    
    // 阻尼
    this.vx *= 0.9;
    this.vy *= 0.9;
    
    this.x += this.vx;
    this.y += this.vy;
  }
  
  draw(ctx: CanvasRenderingContext2D) {
    ctx.beginPath();
    ctx.arc(this.x, this.y, 1.5, 0, Math.PI * 2);
    ctx.fill();
  }
}

// 粒子数组
const textParticles: TextParticle[] = [];
const dotParticles: DotParticle[] = [];
const phrases = [
  // 技术术语
  'JVM', 'AQS', 'CAS', 'MVCC', 'Binlog', 'NIO', 'pprof', 'LZ4', 'gRPC',
  // AI / ML
  'LLM', 'RAG', 'Embedding', 'Prompt', 'Transformer', 'Token', 'Fine-tune', 'Vector', 'Attention', 'RLHF',
  // 彩蛋
  'O(log n)', '// TODO', '0xCAFE', 'null', '42', 'NaN',
];

function resize() {
  width = window.innerWidth;
  height = window.innerHeight;
  canvas.width = width * dpr;
  canvas.height = height * dpr;
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  initParticles();
}

function initParticles() {
  textParticles.length = 0;
  dotParticles.length = 0;
  
  // 文字粒子 - 增加数量
  const textCount = Math.min(Math.floor((width * height) / 25000), 40);
  for (let i = 0; i < textCount; i++) {
    const text = phrases[Math.floor(Math.random() * phrases.length)];
    textParticles.push(new TextParticle(
      text,
      Math.random() * width,
      Math.random() * height
    ));
  }
  
  // 网格点粒子
  const spacing = 50;
  for (let x = spacing; x < width; x += spacing) {
    for (let y = spacing; y < height; y += spacing) {
      dotParticles.push(new DotParticle(x, y));
    }
  }
}

function animate() {
  ctx.clearRect(0, 0, width, height);
  
  // 获取小猫和鼠标位置
  const nekoPos = window.NEKO_POSITION || { x: width / 2, y: height / 2 };
  const mousePos = window.MOUSE_POSITION || { x: width / 2, y: height / 2 };
  
  // 绘制网格点
  ctx.globalAlpha = 0.08;
  ctx.fillStyle = '#818cf8';
  for (const dot of dotParticles) {
    dot.update(nekoPos.x, nekoPos.y, mousePos.x, mousePos.y);
    dot.draw(ctx);
  }
  
  // 绘制文字粒子
  for (const particle of textParticles) {
    particle.update(nekoPos.x, nekoPos.y, mousePos.x, mousePos.y);
    particle.draw(ctx);
  }
  
  ctx.globalAlpha = 1;
  requestAnimationFrame(animate);
}

// 初始化
resize();
animate();
window.addEventListener('resize', resize);
</script>

<style>
  #ripple-canvas {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
  }
</style>
