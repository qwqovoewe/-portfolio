---
interface Props {
  title: string;
  description?: string;
  currentPage?: string;
  robots?: string;
}

import Oneko from '../components/Oneko.astro';
import RippleText from '../components/RippleText.astro';
import { navItems, profile } from '../data/content';

const { title, description, currentPage = 'home', robots = 'index, follow' } = Astro.props;
const base = import.meta.env.BASE_URL;

// 判断是否在主页
const isHomePage = currentPage === 'home';

const defaultDescription = '王睿轩 - 后端工程师 | 华中农业大学 | 专注于高并发架构设计与性能优化';
const pageDescription = description || defaultDescription;
const pageTitle = title;
const siteOrigin = 'https://qwqovoewe.github.io';
const canonicalUrl = `${siteOrigin}${Astro.url.pathname}`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>

    <!-- SEO Meta Tags -->
    <meta name="description" content={pageDescription}>
    <meta name="keywords" content="王睿轩,后端开发,Java,高并发,Redis,Kafka,简历,Portfolio,华中农业大学">
    <meta name="author" content="王睿轩">
    <meta name="robots" content={robots}>
    <link rel="canonical" href={canonicalUrl}>

    <!-- Open Graph / Social Media -->
    <meta property="og:type" content="website">
    <meta property="og:url" content={canonicalUrl}>
    <meta property="og:title" content={pageTitle}>
    <meta property="og:description" content={pageDescription}>
    <meta property="og:locale" content="zh_CN">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={pageTitle}>
    <meta name="twitter:description" content={pageDescription}>

    <!-- Theme Color -->
    <meta name="theme-color" content="#818cf8">
    <meta name="msapplication-TileColor" content="#818cf8">
  </head>
  <body class="min-h-screen flex flex-col">
    <Oneko />
    {isHomePage && <RippleText />}
    
    <!-- Scroll Progress Indicator -->
    <div id="scroll-progress" class="fixed top-0 left-0 right-0 h-0.5 bg-accent/50 z-[60] origin-left scale-x-0"></div>
    
    <!-- Section Dots Navigation -->
    <div id="section-dots" class="fixed right-6 top-1/2 -translate-y-1/2 z-50 hidden md:flex flex-col gap-3">
      <button data-section="hero" class="section-dot w-3 h-3 rounded-full bg-border hover:bg-accent/50 transition-all" title="首页"></button>
      <button data-section="projects" class="section-dot w-3 h-3 rounded-full bg-border hover:bg-accent/50 transition-all" title="作品集"></button>
      <button data-section="timeline" class="section-dot w-3 h-3 rounded-full bg-border hover:bg-accent/50 transition-all" title="时间线"></button>
      <button data-section="articles" class="section-dot w-3 h-3 rounded-full bg-border hover:bg-accent/50 transition-all" title="文章"></button>
      <button data-section="about" class="section-dot w-3 h-3 rounded-full bg-border hover:bg-accent/50 transition-all" title="关于"></button>
    </div>
    
    <!-- 传递当前页面信息给客户端脚本 -->
    <script define:vars={{ isHomePage, base }}>
      window.IS_HOME_PAGE = isHomePage;
      window.BASE_URL = base;
    </script>
    
    <nav class="fixed top-0 left-0 right-0 z-50 border-b border-border/50 bg-bg/60 backdrop-blur-xl shadow-sm shadow-black/5">
      <div class="mx-auto max-w-5xl flex items-center justify-between px-6 h-16">
        <a href={`${base}`} class="text-lg font-bold tracking-tight text-accent">{profile.nameEn.split(' ')[0]}</a>
        <div class="flex items-center gap-2">
          <ul class="flex items-center gap-1">
            {navItems.map((item) => (
              <li>
                <a
                  href={isHomePage ? item.href : `${base}${item.href}`}
                  class="nav-link px-3 py-1.5 rounded-md text-sm text-text-muted hover:text-text hover:bg-surface-hover transition-all duration-200"
                >
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
          <!-- 主题切换按钮 -->
          <button
            id="theme-toggle"
            class="p-2 rounded-lg hover:bg-surface-hover transition-all duration-200 text-text-muted hover:text-text"
            title="切换主题"
          >
            <!-- 月亮图标 - 深色主题显示 -->
            <svg class="w-5 h-5 theme-icon-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
            <!-- 太阳图标 - 亮色主题显示 -->
            <svg class="w-5 h-5 theme-icon-light hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
          </button>
        </div>
      </div>
    </nav>

    <main class="flex-1 pt-16">
      <slot />
    </main>
  </body>
</html>

<script>
  // 主题切换 - 深色主题是默认的
  const themeToggle = document.getElementById('theme-toggle');
  const html = document.documentElement;
  const darkIcon = document.querySelector('.theme-icon-dark');
  const lightIcon = document.querySelector('.theme-icon-light');
  
  // 只检查用户保存的主题偏好，不检测系统偏好
  // 深色主题是默认的，所以只有当用户明确选择了亮色主题时才切换
  const savedTheme = localStorage.getItem('theme');
  
  if (savedTheme === 'light') {
    html.setAttribute('data-theme', 'light');
    darkIcon?.classList.add('hidden');
    lightIcon?.classList.remove('hidden');
  }
  
  themeToggle?.addEventListener('click', () => {
    const currentTheme = html.getAttribute('data-theme');
    
    if (currentTheme === 'light') {
      // 切换到深色主题
      html.removeAttribute('data-theme');
      localStorage.setItem('theme', 'dark');
      darkIcon?.classList.remove('hidden');
      lightIcon?.classList.add('hidden');
    } else {
      // 切换到亮色主题
      html.setAttribute('data-theme', 'light');
      localStorage.setItem('theme', 'light');
      darkIcon?.classList.add('hidden');
      lightIcon?.classList.remove('hidden');
    }
  });

  // Scroll progress bar
  const scrollProgress = document.getElementById('scroll-progress');
  
  function updateScrollProgress() {
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const progress = docHeight > 0 ? scrollTop / docHeight : 0;
    if (scrollProgress) {
      scrollProgress.style.transform = `scaleX(${progress})`;
    }
  }
  
  window.addEventListener('scroll', updateScrollProgress);
  updateScrollProgress();

  // Section dots navigation
  const sections = ['hero', 'projects', 'timeline', 'articles', 'about'];
  const dots = document.querySelectorAll('.section-dot');
  const isHomePage = (window as any).IS_HOME_PAGE !== false;
  
  function updateActiveDot() {
    // 只在主页更新高亮状态
    if (!isHomePage) return;
    
    const scrollY = window.scrollY + window.innerHeight / 2;
    let current = 'hero';
    
    for (const id of sections) {
      const el = document.getElementById(id);
      if (el && el.offsetTop <= scrollY) {
        current = id;
      }
    }
    
    dots.forEach(dot => {
      const sectionId = (dot as HTMLElement).dataset.section;
      if (sectionId === current) {
        dot.classList.add('bg-accent', 'scale-125');
        dot.classList.remove('bg-border');
      } else {
        dot.classList.remove('bg-accent', 'scale-125');
        dot.classList.add('bg-border');
      }
    });
  }
  
  window.addEventListener('scroll', updateActiveDot);
  updateActiveDot();
  
  // Click dot to scroll or navigate
  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      const sectionId = (dot as HTMLElement).dataset.section;
      const el = document.getElementById(sectionId || '');
      
      if (isHomePage && el) {
        // 在主页，直接滚动
        el.scrollIntoView({ behavior: 'smooth' });
      } else {
        // 在其他页面，跳转到主页对应位置
        const baseUrl = (window as any).BASE_URL || '/';
        window.location.href = baseUrl + (sectionId ? `#${sectionId}` : '');
      }
    });
  });
</script>

<style is:global>
  @import '../styles/global.css';
</style>
