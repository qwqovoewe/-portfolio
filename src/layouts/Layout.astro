---
interface Props {
  title: string;
  currentPage?: string; // 用于标识当前页面
}

import Oneko from '../components/Oneko.astro';
import { navItems, profile } from '../data/content';

const { title, currentPage = 'home' } = Astro.props;
const base = import.meta.env.BASE_URL;

// 判断是否在主页
const isHomePage = currentPage === 'home';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <Oneko />
    
    <!-- Scroll Progress Indicator -->
    <div id="scroll-progress" class="fixed top-0 left-0 right-0 h-0.5 bg-accent/50 z-[60] origin-left scale-x-0"></div>
    
    <!-- Section Dots Navigation -->
    <div id="section-dots" class="fixed right-6 top-1/2 -translate-y-1/2 z-50 hidden md:flex flex-col gap-3">
      <button data-section="hero" class="section-dot w-3 h-3 rounded-full bg-border hover:bg-accent/50 transition-all" title="首页"></button>
      <button data-section="projects" class="section-dot w-3 h-3 rounded-full bg-border hover:bg-accent/50 transition-all" title="作品集"></button>
      <button data-section="timeline" class="section-dot w-3 h-3 rounded-full bg-border hover:bg-accent/50 transition-all" title="时间线"></button>
      <button data-section="about" class="section-dot w-3 h-3 rounded-full bg-border hover:bg-accent/50 transition-all" title="关于"></button>
    </div>
    
    <!-- 传递当前页面信息给客户端脚本 -->
    <script define:vars={{ isHomePage }}>
      window.IS_HOME_PAGE = isHomePage;
    </script>
    
    <nav class="fixed top-0 left-0 right-0 z-50 border-b border-border bg-bg/80 backdrop-blur-md">
      <div class="mx-auto max-w-5xl flex items-center justify-between px-6 h-16">
        <a href={`${base}`} class="text-lg font-bold tracking-tight text-accent">{profile.nameEn.split(' ')[0]}</a>
        <ul class="flex items-center gap-1">
          {navItems.map((item) => (
            <li>
              <a
                href={isHomePage ? item.href : `${base}${item.href}`}
                class="nav-link px-3 py-1.5 rounded-md text-sm text-text-muted hover:text-text hover:bg-surface-hover transition-all duration-200"
              >
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>

    <main class="flex-1 pt-16">
      <slot />
    </main>
  </body>
</html>

<script>
  // Scroll progress bar
  const scrollProgress = document.getElementById('scroll-progress');
  
  function updateScrollProgress() {
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const progress = docHeight > 0 ? scrollTop / docHeight : 0;
    if (scrollProgress) {
      scrollProgress.style.transform = `scaleX(${progress})`;
    }
  }
  
  window.addEventListener('scroll', updateScrollProgress);
  updateScrollProgress();

  // Section dots navigation
  const sections = ['hero', 'projects', 'timeline', 'about'];
  const dots = document.querySelectorAll('.section-dot');
  const isHomePage = (window as any).IS_HOME_PAGE !== false;
  
  function updateActiveDot() {
    // 只在主页更新高亮状态
    if (!isHomePage) return;
    
    const scrollY = window.scrollY + window.innerHeight / 2;
    let current = 'hero';
    
    for (const id of sections) {
      const el = document.getElementById(id);
      if (el && el.offsetTop <= scrollY) {
        current = id;
      }
    }
    
    dots.forEach(dot => {
      const sectionId = (dot as HTMLElement).dataset.section;
      if (sectionId === current) {
        dot.classList.add('bg-accent', 'scale-125');
        dot.classList.remove('bg-border');
      } else {
        dot.classList.remove('bg-accent', 'scale-125');
        dot.classList.add('bg-border');
      }
    });
  }
  
  window.addEventListener('scroll', updateActiveDot);
  updateActiveDot();
  
  // Click dot to scroll or navigate
  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      const sectionId = (dot as HTMLElement).dataset.section;
      const el = document.getElementById(sectionId || '');
      
      if (isHomePage && el) {
        // 在主页，直接滚动
        el.scrollIntoView({ behavior: 'smooth' });
      } else {
        // 在其他页面，跳转到主页对应位置
        window.location.href = '/' + (sectionId ? `#${sectionId}` : '');
      }
    });
  });
</script>

<style is:global>
  @import '../styles/global.css';
</style>
