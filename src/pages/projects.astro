---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/content';

const base = import.meta.env.BASE_URL;
---

<Layout title="作品集 | Portfolio" currentPage="projects">
  <section class="mx-auto max-w-5xl px-6 py-20">
    <h1 class="text-4xl font-bold tracking-tight mb-2">项目经历</h1>
    <p class="text-text-muted mb-12">过往实习经历及独立开发的项目，涵盖高并发架构、性能优化与AI应用。</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map((project) => (
        <a
          href={`${base}/projects/${project.slug}`}
          class="project-card group block rounded-xl border border-border bg-surface p-6 relative overflow-hidden"
        >
          {project.type === "实习项目" && (
            <div class="absolute top-3 right-3 px-2 py-0.5 text-xs font-medium bg-accent/20 text-accent rounded-full">
              {project.type}
            </div>
          )}
          <div class="mb-4 flex items-center justify-between">
            <svg class="w-8 h-8 text-accent transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
            </svg>
            <svg class="w-5 h-5 text-text-muted opacity-0 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7v10" />
            </svg>
          </div>
          <p class="text-xs text-text-muted mb-1 font-mono">{project.company} · {project.period}</p>
          <h3 class="text-lg font-semibold mb-2 transition-colors duration-300 group-hover:text-accent">{project.name}</h3>
          <p class="text-sm text-text-muted mb-4 leading-relaxed">{project.description}</p>
          <div class="flex flex-wrap gap-2">
            {project.techStack.map((tag) => (
              <span class="text-xs px-2 py-0.5 rounded-full bg-accent/10 text-accent transition-colors duration-300 group-hover:bg-accent/20">
                {tag}
              </span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
  .project-card {
    transform: translateY(0);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
  }

  .project-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(135deg, transparent 0%, rgba(129, 140, 248, 0.3) 50%, transparent 100%);
    background-size: 200% 200%;
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .project-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(129, 140, 248, 0.15), 0 0 0 1px rgba(129, 140, 248, 0.1);
  }

  .project-card:hover::before {
    opacity: 1;
  }
</style>
