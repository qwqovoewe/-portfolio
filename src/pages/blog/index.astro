---
import Layout from '../../layouts/Layout.astro';
import { articles } from '../../data/content';
---

<Layout title="文章 | Portfolio" currentPage="blog">
  <section class="mx-auto max-w-3xl px-6 py-20">
    <h1 class="text-4xl font-bold tracking-tight mb-2">文章</h1>
    <p class="text-text-muted mb-12">记录技术思考与分享，发布于不同平台。</p>

    <div class="space-y-5">
      {articles.map((article) => (
        <a
          href={article.url.startsWith('http') ? article.url : `${import.meta.env.BASE_URL}${article.url}`}
          {...(article.url.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          class="group flex gap-5 p-5 rounded-xl border border-border bg-surface hover:border-accent/30 hover:bg-surface-hover transition-all"
        >
          <div class="flex-shrink-0 pt-0.5">
            <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-accent/10 text-accent text-xs font-bold border border-accent/20">
              {article.platform.charAt(0)}
            </span>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex flex-wrap items-center gap-2 mb-1">
              {article.label && (
                <span class="text-xs text-text-muted">{article.label}</span>
              )}
              <span class="text-xs px-1.5 py-0.5 rounded bg-surface-hover border border-border text-text-muted">{article.platform}</span>
              <span class="text-xs text-text-muted font-mono">{article.date}</span>
            </div>
            <h2 class="text-lg font-semibold mb-1.5 group-hover:text-accent transition-colors leading-snug">
              {article.title}
            </h2>
            <p class="text-sm text-text-muted leading-relaxed mb-3">{article.description}</p>
            <div class="flex flex-wrap gap-1.5">
              {article.tags.map((tag) => (
                <span class="text-xs px-2 py-0.5 rounded-full bg-accent/10 text-accent">{tag}</span>
              ))}
            </div>
          </div>
          <div class="flex-shrink-0 self-center opacity-0 group-hover:opacity-100 transition-opacity">
            <svg class="w-4 h-4 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7v10" />
            </svg>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
