---
import Layout from '../layouts/Layout.astro';
import {
  profile,
  projects,
  milestones,
  techSkills,
  articles,
} from '../data/content';

// 为 JavaScript 交互准备数据
const skillsData = Object.entries(techSkills).map(([category, data]) => ({
  id: category.toLowerCase().replace(/\s+/g, '-'),
  category,
  description: `熟悉${category}相关技术`,
  details: Object.entries(data.details).map(([title, content]) => ({ title, content })),
}));

const projectsData = projects.map(p => ({
  id: p.name.toLowerCase().replace(/\s+/g, '-'),
  title: p.name,
  role: p.role,
  time: p.period,
  company: p.company || '个人项目',
  overview: p.description,
  achievements: p.highlights,
  tech: p.techStack,
}));

---
<Layout title="Ruixuan | Portfolio" currentPage="home">
  <!-- Hero Section -->
  <section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <div id="hero-overlay" class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-bg pointer-events-none"></div>
    
    <div class="relative z-10 text-center px-6 hero-content">
      <p class="text-text-muted text-sm tracking-widest uppercase mb-4 animate-fade-in-up">Welcome</p>
      <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6 animate-fade-in-up animation-delay-100">
        Hi, I'm <span class="text-accent">{profile.nameEn}</span>
      </h1>
      <p class="text-lg md:text-xl text-text-muted max-w-2xl mx-auto mb-4 animate-fade-in-up animation-delay-200">
        {profile.title}
      </p>
      <div class="flex items-center justify-center gap-4 animate-fade-in-up animation-delay-300">
        <a href="#projects" class="nav-link px-6 py-2.5 bg-accent text-white rounded-lg text-sm font-medium transition-all duration-200 ease-out hover:bg-accent-hover hover:shadow-lg hover:shadow-accent/25 hover:-translate-y-0.5 active:translate-y-0">查看作品</a>
        <a href="#about" class="nav-link px-6 py-2.5 border border-border rounded-lg text-sm font-medium transition-all duration-200 ease-out text-text-muted hover:text-text hover:border-accent/50 hover:bg-surface-hover hover:-translate-y-0.5 active:translate-y-0">了解更多</a>
      </div>
    </div>
    
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce scroll-indicator">
      <svg class="w-6 h-6 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  <!-- Projects Section -->
  <section id="projects" class="min-h-screen py-32 px-6 relative">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="parallax-bg absolute -top-1/4 -left-1/4 w-1/2 h-1/2 bg-accent/5 rounded-full blur-3xl"></div>
    </div>
    
    <div class="mx-auto max-w-5xl relative z-10">
      <div class="section-title mb-12">
        <h2 class="text-4xl font-bold tracking-tight mb-2">项目经历</h2>
        <p class="text-text-muted">过往实习经历及独立开发的项目，涵盖高并发架构、性能优化与AI应用。</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {projects.map((project, i) => (
          <a href={`${import.meta.env.BASE_URL}/projects/${project.slug}`} class="project-card section-animate group block rounded-xl border border-border bg-surface p-6 relative overflow-hidden" style={`transition-delay: ${i * 100}ms`}>
            {project.type === "实习项目" && (
              <div class="absolute top-3 right-3 px-2 py-0.5 text-xs font-medium bg-accent/20 text-accent rounded-full">{project.type}</div>
            )}
            <div class="mb-4 flex items-center justify-between">
              <svg class="w-8 h-8 text-accent transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
              </svg>
              <svg class="w-5 h-5 text-text-muted opacity-0 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7v10" />
              </svg>
            </div>
            <p class="text-xs text-text-muted mb-1 font-mono">{project.company} · {project.period}</p>
            <h3 class="text-lg font-semibold mb-2 transition-colors duration-300 group-hover:text-accent">{project.name}</h3>
            <p class="text-sm text-text-muted mb-4 leading-relaxed">{project.description}</p>
            <div class="flex flex-wrap gap-2">
              {project.techStack.map((tag) => (<span class="text-xs px-2 py-0.5 rounded-full bg-accent/10 text-accent transition-colors duration-300 group-hover:bg-accent/20">{tag}</span>))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Skill Modal -->
  <div id="skill-modal" class="fixed inset-0 z-[100] hidden">
    <div class="absolute inset-0 bg-bg/80 backdrop-blur-sm" id="skill-modal-backdrop"></div>
    <div class="absolute inset-4 md:inset-8 lg:inset-16 overflow-y-auto">
      <div class="min-h-full flex items-start justify-center py-8">
        <div id="skill-modal-content" class="relative w-full max-w-2xl bg-surface border border-border rounded-2xl shadow-2xl opacity-0 transform scale-95 transition-all duration-300">
          <button id="skill-modal-close" class="absolute top-4 right-4 p-2 rounded-lg hover:bg-surface-hover transition-colors text-text-muted hover:text-text">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
          <div id="skill-modal-body" class="p-8">
            <!-- Content will be injected here -->
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Timeline Section -->
  <section id="timeline" class="min-h-screen py-32 px-6 relative bg-surface/50">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="parallax-bg absolute top-1/4 right-0 w-1/3 h-1/2 bg-blue-500/5 rounded-full blur-3xl"></div>
    </div>
    
    <div class="mx-auto max-w-3xl relative z-10">
      <div class="section-title mb-16">
        <h2 class="text-4xl font-bold tracking-tight mb-2">成长历程</h2>
        <p class="text-text-muted">从校园到职场的成长路径与关键里程碑。</p>
      </div>

      <div class="relative">
        <div class="absolute left-6 top-0 bottom-0 w-px bg-border"></div>
        <div class="space-y-12">
          {milestones.map((m, i) => (
            <div class="slide-left relative pl-16" style={`transition-delay: ${i * 150}ms`}>
              <div class="absolute left-4 top-1 w-5 h-5 rounded-full border-2 border-accent bg-bg flex items-center justify-center text-xs timeline-node">{m.icon}</div>
              <span class="text-xs font-mono text-accent tracking-wider">{m.date}</span>
              <h3 class="text-xl font-semibold mt-1 mb-2">{m.title}</h3>
              <p class="text-text-muted leading-relaxed">{m.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Articles Section -->
  <section id="articles" class="py-32 px-6 relative bg-surface/50">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="parallax-bg absolute top-0 right-1/4 w-1/3 h-1/2 bg-accent/5 rounded-full blur-3xl"></div>
    </div>

    <div class="mx-auto max-w-3xl relative z-10">
      <div class="section-title mb-12">
        <h2 class="text-4xl font-bold tracking-tight mb-2">文章</h2>
        <p class="text-text-muted">记录技术思考与分享，发布于不同平台。</p>
      </div>

      <div class="space-y-5">
        {articles.map((article, i) => (
          <a
            href={article.url}
            target="_blank"
            rel="noopener noreferrer"
            class="section-animate group flex gap-5 p-5 rounded-xl border border-border bg-surface hover:border-accent/30 hover:bg-surface-hover transition-all"
            style={`transition-delay: ${i * 80}ms`}
          >
            <div class="flex-shrink-0 pt-0.5">
              <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-accent/10 text-accent text-xs font-bold border border-accent/20">
                {article.platform.charAt(0)}
              </span>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex flex-wrap items-center gap-2 mb-1">
                {article.label && (
                  <span class="text-xs text-text-muted">{article.label}</span>
                )}
                <span class="text-xs px-1.5 py-0.5 rounded bg-surface-hover border border-border text-text-muted">{article.platform}</span>
                <span class="text-xs text-text-muted font-mono">{article.date}</span>
              </div>
              <h3 class="text-base font-semibold mb-1.5 group-hover:text-accent transition-colors leading-snug">
                {article.title}
              </h3>
              <p class="text-sm text-text-muted leading-relaxed mb-3">{article.description}</p>
              <div class="flex flex-wrap gap-1.5">
                {article.tags.map((tag) => (
                  <span class="text-xs px-2 py-0.5 rounded-full bg-accent/10 text-accent">{tag}</span>
                ))}
              </div>
            </div>
            <div class="flex-shrink-0 self-center opacity-0 group-hover:opacity-100 transition-opacity">
              <svg class="w-4 h-4 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7v10" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="min-h-screen py-32 px-6 relative">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="parallax-bg absolute bottom-0 left-1/4 w-1/2 h-1/2 bg-green-500/5 rounded-full blur-3xl"></div>
    </div>
    
    <div class="mx-auto max-w-3xl relative z-10">
      <div class="section-title mb-12">
        <h2 class="text-4xl font-bold tracking-tight mb-2">关于我</h2>
        <p class="text-text-muted">了解更多关于我的信息。</p>
      </div>

      <div class="space-y-12">
        <div class="section-animate rounded-xl border border-border bg-surface p-8">
          {profile.bio.map((para, i) => (
            <p class={`text-${i === 0 ? 'lg' : 'text'} leading-relaxed ${i < profile.bio.length - 1 ? 'mb-4' : ''} ${i > 0 ? 'text-text-muted' : ''}`}>{para}</p>
          ))}
        </div>

        <div class="section-animate">
          <h3 class="text-2xl font-semibold mb-6">技术栈</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {Object.entries(techSkills).map(([category, data], i) => (
              <button data-skill-id={category.toLowerCase().replace(/\s+/g, '-')} class="skill-card group rounded-xl border border-border bg-surface p-6 hover:border-accent/40 transition-all text-left" style={`transition-delay: ${i * 50}ms`}>
                <div class="flex items-center justify-between mb-3">
                  <h4 class="text-sm font-medium text-accent">{category}</h4>
                  <svg class="w-4 h-4 text-text-muted opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </div>
                <ul class="space-y-2">
                  {data.items.map((item) => (<li class="text-sm text-text-muted flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-accent/50"></span>{item}</li>))}
                </ul>
              </button>
            ))}
          </div>
        </div>

        <div class="section-animate">
          <h3 class="text-2xl font-semibold mb-6">荣誉奖项</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {profile.awards.map((award) => (
              <div class="flex items-center gap-3 p-4 rounded-xl border border-border bg-surface">
                <span class="text-2xl">{award.icon}</span>
                <div>
                  <p class="font-medium">{award.name}</p>
                  <p class="text-sm text-text-muted">{award.level}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="section-animate">
          <h3 class="text-2xl font-semibold mb-6">联系我</h3>
          
          <!-- 下载简历按钮 -->
          <a href={`${import.meta.env.BASE_URL}/resume.pdf`} download="王睿轩-后端工程师.pdf" class="flex items-center gap-3 px-5 py-4 rounded-xl border border-accent/30 bg-accent/10 hover:bg-accent/20 hover:border-accent/50 transition-all group mb-4">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            <div class="flex-1">
              <p class="font-medium text-accent">下载简历</p>
              <p class="text-sm text-text-muted">PDF格式，点击下载</p>
            </div>
            <svg class="w-5 h-5 text-accent opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          </a>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <a href={profile.contact.github.url} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 px-5 py-4 rounded-xl border border-border bg-surface hover:border-accent/40 hover:bg-surface-hover transition-all group">
              <svg class="w-6 h-6 text-accent" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
              <div>
                <p class="font-medium group-hover:text-accent transition-colors">GitHub</p>
                <p class="text-sm text-text-muted">github.com/{profile.contact.github.username}</p>
              </div>
            </a>
            <button class="copy-btn flex items-center gap-3 px-5 py-4 rounded-xl border border-border bg-surface hover:border-accent/40 hover:bg-surface-hover transition-all group text-left" data-copy={profile.contact.email}>
              <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              <div class="flex-1">
                <p class="font-medium group-hover:text-accent transition-colors">Email</p>
                <p class="text-sm text-text-muted copy-text">{profile.contact.email}</p>
              </div>
              <span class="copy-hint text-xs text-accent opacity-0 group-hover:opacity-100 transition-opacity">点击复制</span>
            </button>

          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-8 px-6 border-t border-border">
    <div class="mx-auto max-w-5xl text-center space-y-2">
      <p class="text-sm text-text-muted">© 2026 {profile.nameEn}. Built with Astro + Tailwind CSS.</p>
      <p class="text-xs text-text-muted/60">💡 本站内容由个人 OpenClaw 基于个人知识库生成，详情请以简历为准</p>
    </div>
  </footer>
  
  <!-- 光标跟随光晕 -->
  <div class="cursor-glow" id="cursor-glow"></div>
</Layout>

<style>
  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  @keyframes slide-in-left {
    from { opacity: 0; transform: translateX(-60px); }
    to { opacity: 1; transform: translateX(0); }
  }
  
  @keyframes scale-in {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
  }
  
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }
  
  /* 背景渐变流动 */
  @keyframes gradient-flow {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  
  /* 时间线脉冲 */
  @keyframes pulse-ring {
    0% { transform: scale(1); opacity: 0.8; }
    50% { transform: scale(1.2); opacity: 0.4; }
    100% { transform: scale(1); opacity: 0.8; }
  }
  
  /* 卡片边缘流光 */
  @keyframes border-glow {
    0% { background-position: 0% 50%; }
    100% { background-position: 200% 50%; }
  }
  
  .animate-fade-in-up { animation: fade-in-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  .animate-slide-in-left { animation: slide-in-left 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  .animate-scale-in { animation: scale-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  .animate-float { animation: float 3s ease-in-out infinite; }
  
  .animation-delay-100 { animation-delay: 100ms; }
  .animation-delay-200 { animation-delay: 200ms; }
  .animation-delay-300 { animation-delay: 300ms; }
  
  .section-animate { 
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1), 
                transform 1s cubic-bezier(0.16, 1, 0.3, 1); 
  }
  
  .section-animate.visible { 
    opacity: 1 !important; 
    transform: translateY(0) !important; 
  }
  
  /* Slide in from left for timeline */
  .slide-left {
    opacity: 0;
    transform: translateX(-60px);
    transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1),
                transform 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .slide-left.visible {
    opacity: 1 !important;
    transform: translateX(0) !important;
  }
  
  html { scroll-behavior: smooth; }
  
  /* 背景渐变流动效果 */
  body::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(
      135deg,
      rgba(129, 140, 248, 0.03) 0%,
      rgba(99, 102, 241, 0.02) 25%,
      rgba(139, 92, 246, 0.03) 50%,
      rgba(99, 102, 241, 0.02) 75%,
      rgba(129, 140, 248, 0.03) 100%
    );
    background-size: 400% 400%;
    animation: gradient-flow 20s ease infinite;
    pointer-events: none;
    z-index: 0;
  }
  
  /* 光标跟随光晕 */
  .cursor-glow {
    position: fixed;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(129, 140, 248, 0.08) 0%, transparent 70%);
    pointer-events: none;
    z-index: 1;
    transform: translate(-50%, -50%);
    transition: opacity 0.3s ease;
    opacity: 0;
  }
  
  .cursor-glow.active {
    opacity: 1;
  }
  
  /* Fixed Hero Section - GitHub Style */
  #hero {
    position: fixed;
    top: 64px; /* nav height */
    left: 0;
    right: 0;
    height: 100vh;
    z-index: 0;
    pointer-events: auto;
  }
  
  /* Content sections on top - start AFTER hero */
  #projects {
    position: relative;
    z-index: 10;
    background: var(--bg);
    margin-top: 100vh; /* Start after hero */
  }
  
  #timeline, #articles, #about, footer {
    position: relative;
    z-index: 10;
    background: var(--bg);
  }
  
  /* Hero canvas parallax */
  .hero-parallax {
    will-change: transform;
  }
  
  /* Hero content fade on scroll */
  .hero-content {
    will-change: transform, opacity;
    transition: opacity 0.3s, transform 0.3s;
  }
  
  /* Project card hover effect with edge glow */
  .project-card {
    transform: translateY(0);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
  }
  
  .project-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(
      135deg,
      transparent 0%,
      rgba(129, 140, 248, 0.3) 50%,
      transparent 100%
    );
    background-size: 200% 200%;
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  
  .project-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(129, 140, 248, 0.15), 
                0 0 0 1px rgba(129, 140, 248, 0.1);
  }
  
  .project-card:hover::before {
    opacity: 1;
    animation: border-glow 2s linear infinite;
  }
  
  /* Section titles slide from left */
  .section-title {
    opacity: 0;
    transform: translateX(-40px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .section-title.visible {
    opacity: 1;
    transform: translateX(0);
  }
  
  /* Skill card hover effect */
  .skill-card {
    cursor: pointer;
  }
  
  .skill-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(129, 140, 248, 0.1);
  }
  
  /* 时间线节点脉冲效果 */
  .timeline-node {
    position: relative;
  }
  
  .timeline-node::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 1px solid rgba(129, 140, 248, 0.4);
    animation: pulse-ring 3s ease-in-out infinite;
  }
</style>

<script define:vars={{ skillsData }}>
  // Pass skills data from server to client (global)
  window.SKILLS_DATA = skillsData;
</script>

<script>
  // 光标跟随光晕效果
  const cursorGlow = document.getElementById('cursor-glow');
  let cursorX = 0, cursorY = 0;
  let currentX = 0, currentY = 0;
  
  document.addEventListener('mousemove', (e) => {
    cursorX = e.clientX;
    cursorY = e.clientY;
    cursorGlow?.classList.add('active');
  });
  
  document.addEventListener('mouseleave', () => {
    cursorGlow?.classList.remove('active');
  });
  
  function animateCursor() {
    // 平滑跟随
    currentX += (cursorX - currentX) * 0.1;
    currentY += (cursorY - currentY) * 0.1;
    
    if (cursorGlow) {
      cursorGlow.style.left = currentX + 'px';
      cursorGlow.style.top = currentY + 'px';
    }
    requestAnimationFrame(animateCursor);
  }
  animateCursor();

  // Scroll-triggered animations
  const sectionObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.15, rootMargin: '0px 0px -100px 0px' });

  // Observe all animated elements
  document.querySelectorAll('.section-animate, .section-title, .slide-left').forEach(el => {
    sectionObserver.observe(el);
  });

  // Hero parallax effect - GitHub style
  const heroContent = document.querySelector('.hero-content');
  const scrollIndicator = document.querySelector('.scroll-indicator');
  
  let ticking = false;
  
  function updateHeroParallax() {
    const scrollY = window.scrollY;
    const heroHeight = window.innerHeight;
    const progress = Math.min(scrollY / (heroHeight * 0.5), 1);
    
    // Content fades out and moves up
    if (heroContent) {
      (heroContent as HTMLElement).style.transform = `translateY(${scrollY * 0.3}px)`;
      (heroContent as HTMLElement).style.opacity = `${1 - progress * 1.5}`;
    }
    
    // Scroll indicator fades out quickly
    if (scrollIndicator) {
      (scrollIndicator as HTMLElement).style.opacity = `${1 - progress * 4}`;
    }
    
    ticking = false;
  }

  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(updateHeroParallax);
      ticking = true;
    }
  }, { passive: true });


  // Copy to clipboard functionality
  document.querySelectorAll('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = (btn as HTMLElement).dataset.copy;
      if (!text) return;
      
      try {
        await navigator.clipboard.writeText(text);
        const hint = btn.querySelector('.copy-hint') as HTMLElement;
        const originalText = hint.textContent;
        hint.textContent = '已复制!';
        hint.style.opacity = '1';
        
        setTimeout(() => {
          hint.textContent = originalText;
          hint.style.opacity = '';
        }, 1500);
      } catch (err) {
        console.error('Failed to copy:', err);
      }
    });
  });

  // Project modal replaced by /projects/[slug] page

  const skillsData = (window as any).SKILLS_DATA;

  const skillModal = document.getElementById('skill-modal');
  const skillModalContent = document.getElementById('skill-modal-content');
  const skillModalBody = document.getElementById('skill-modal-body');
  const skillModalClose = document.getElementById('skill-modal-close');
  const skillModalBackdrop = document.getElementById('skill-modal-backdrop');

  function openSkillModal(skillId: string) {
    const skill = skillsData.find(s => s.id === skillId);
    if (!skill || !skillModal || !skillModalBody || !skillModalContent) return;

    skillModalBody.innerHTML = `
      <div class="mb-6">
        <h2 class="text-2xl font-bold mb-2">${skill.category}</h2>
        <p class="text-text-muted leading-relaxed">${skill.description}</p>
      </div>

      <div>
        <h3 class="text-lg font-semibold mb-4 text-accent">详细技能</h3>
        <div class="space-y-4">
          ${skill.details.map(d => `
            <div class="p-4 rounded-lg border border-border bg-bg/50">
              <h4 class="font-medium mb-2">${d.title}</h4>
              <p class="text-sm text-text-muted">${d.content}</p>
            </div>
          `).join('')}
        </div>
      </div>
    `;

    skillModal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    
    requestAnimationFrame(() => {
      skillModalContent.classList.remove('opacity-0', 'scale-95');
      skillModalContent.classList.add('opacity-100', 'scale-100');
    });
  }

  function closeSkillModal() {
    if (!skillModal || !skillModalContent) return;
    skillModalContent.classList.remove('opacity-100', 'scale-100');
    skillModalContent.classList.add('opacity-0', 'scale-95');
    
    setTimeout(() => {
      skillModal.classList.add('hidden');
      document.body.style.overflow = '';
    }, 300);
  }

  document.querySelectorAll('.skill-card').forEach(card => {
    card.addEventListener('click', () => {
      const skillId = (card as HTMLElement).dataset.skillId;
      if (skillId) openSkillModal(skillId);
    });
  });

  skillModalClose?.addEventListener('click', closeSkillModal);
  skillModalBackdrop?.addEventListener('click', closeSkillModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !skillModal?.classList.contains('hidden')) {
      closeSkillModal();
    }
  });
