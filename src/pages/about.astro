---
import Layout from '../layouts/Layout.astro';

const skills = [
  { category: '前端', items: ['TypeScript', 'React', 'Vue.js', 'Astro', 'Tailwind CSS'] },
  { category: '后端', items: ['Node.js', 'Python', 'PostgreSQL', 'REST API'] },
  { category: '工具', items: ['Git', 'Docker', 'VS Code', 'Figma'] },
];
---

<Layout title="关于我 | Portfolio">
  <section class="mx-auto max-w-3xl px-6 py-20">
    <h1 class="text-4xl font-bold tracking-tight mb-2">关于我</h1>
    <p class="text-text-muted mb-12">了解更多关于我的信息。</p>

    <div class="space-y-12">
      {/* Intro */}
      <div class="rounded-xl border border-border bg-surface p-8">
        <p class="text-lg leading-relaxed mb-4">
          你好！我是一名全栈开发者，热爱用代码创造有价值的产品。
        </p>
        <p class="text-text-muted leading-relaxed mb-4">
          我喜欢探索新技术，关注开发者体验和产品设计。目前专注于现代 Web 开发，
          同时也在学习系统设计和 AI 应用开发。
        </p>
        <p class="text-text-muted leading-relaxed">
          工作之余，我喜欢阅读、写作技术博客，偶尔也会参与开源项目贡献。
          相信持续学习和分享是成长的最好方式。
        </p>
      </div>

      {/* Skills */}
      <div>
        <h2 class="text-2xl font-semibold mb-6">技术栈</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {skills.map((group) => (
            <div class="rounded-xl border border-border bg-surface p-6">
              <h3 class="text-sm font-medium text-accent mb-4">{group.category}</h3>
              <ul class="space-y-2">
                {group.items.map((item) => (
                  <li class="text-sm text-text-muted flex items-center gap-2">
                    <span class="w-1.5 h-1.5 rounded-full bg-accent/50"></span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>

      {/* Contact */}
      <div>
        <h2 class="text-2xl font-semibold mb-6">联系我</h2>
        <div class="flex flex-wrap gap-4">
          <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-4 py-2 rounded-lg border border-border hover:border-accent/30 hover:bg-surface-hover transition-all text-sm text-text-muted hover:text-text">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            GitHub
          </a>
          <a href="mailto:hello@example.com" class="flex items-center gap-2 px-4 py-2 rounded-lg border border-border hover:border-accent/30 hover:bg-surface-hover transition-all text-sm text-text-muted hover:text-text">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            Email
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
