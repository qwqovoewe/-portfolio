---
import Layout from '../layouts/Layout.astro';
import { profile, techSkills } from '../data/content';

const base = import.meta.env.BASE_URL;
---

<Layout title="关于我 | Portfolio" currentPage="about">
  <section class="mx-auto max-w-3xl px-6 py-20">
    <h1 class="text-4xl font-bold tracking-tight mb-2">关于我</h1>
    <p class="text-text-muted mb-12">了解更多关于我的信息。</p>

    <div class="space-y-12">

      {/* Bio */}
      <div class="rounded-xl border border-border bg-surface p-8">
        {profile.bio.map((para, i) => (
          <p class={`leading-relaxed ${i === 0 ? 'text-lg mb-4' : 'text-text-muted mb-4'} ${i === profile.bio.length - 1 ? 'mb-0' : ''}`}>
            {para}
          </p>
        ))}
      </div>

      {/* Education */}
      <div>
        <h2 class="text-2xl font-semibold mb-6">教育背景</h2>
        <div class="rounded-xl border border-border bg-surface p-6 flex items-center gap-5">
          <span class="text-4xl">🎓</span>
          <div>
            <p class="font-semibold text-lg">{profile.education.school}</p>
            <p class="text-text-muted text-sm">{profile.education.major} · {profile.education.level}</p>
            <p class="text-text-muted text-sm">{profile.education.period}</p>
          </div>
        </div>
      </div>

      {/* Tech Skills */}
      <div>
        <h2 class="text-2xl font-semibold mb-6">技术栈</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {Object.entries(techSkills).map(([category, data]) => (
            <div class="rounded-xl border border-border bg-surface p-6">
              <h3 class="text-sm font-medium text-accent mb-4">{category}</h3>
              <ul class="space-y-2">
                {data.items.map((item) => (
                  <li class="text-sm text-text-muted flex items-center gap-2">
                    <span class="w-1.5 h-1.5 rounded-full bg-accent/50"></span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>

      {/* Awards */}
      <div>
        <h2 class="text-2xl font-semibold mb-6">荣誉奖项</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {profile.awards.map((award) => (
            <div class="flex items-center gap-3 p-4 rounded-xl border border-border bg-surface">
              <span class="text-2xl">{award.icon}</span>
              <div>
                <p class="font-medium">{award.name}</p>
                <p class="text-sm text-text-muted">{award.level}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      {/* Contact */}
      <div>
        <h2 class="text-2xl font-semibold mb-6">联系我</h2>

        <a href={`${base}/resume.pdf`} download="王睿轩-后端工程师.pdf"
          class="flex items-center gap-3 px-5 py-4 rounded-xl border border-accent/30 bg-accent/10 hover:bg-accent/20 hover:border-accent/50 transition-all group mb-4">
          <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          <div class="flex-1">
            <p class="font-medium text-accent">下载简历</p>
            <p class="text-sm text-text-muted">PDF格式，点击下载</p>
          </div>
          <svg class="w-5 h-5 text-accent opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
          </svg>
        </a>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <a href={profile.contact.github.url} target="_blank" rel="noopener noreferrer"
            class="flex items-center gap-3 px-5 py-4 rounded-xl border border-border bg-surface hover:border-accent/40 hover:bg-surface-hover transition-all group">
            <svg class="w-6 h-6 text-accent" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            <div>
              <p class="font-medium group-hover:text-accent transition-colors">GitHub</p>
              <p class="text-sm text-text-muted">github.com/{profile.contact.github.username}</p>
            </div>
          </a>

          <button class="copy-btn flex items-center gap-3 px-5 py-4 rounded-xl border border-border bg-surface hover:border-accent/40 hover:bg-surface-hover transition-all group text-left"
            data-copy={profile.contact.email}>
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <div class="flex-1">
              <p class="font-medium group-hover:text-accent transition-colors">Email</p>
              <p class="text-sm text-text-muted copy-text">{profile.contact.email}</p>
            </div>
            <span class="copy-hint text-xs text-accent opacity-0 group-hover:opacity-100 transition-opacity">点击复制</span>
          </button>
        </div>
      </div>

    </div>
  </section>
</Layout>

<script>
  document.querySelectorAll('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = (btn as HTMLElement).dataset.copy;
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
        const hint = btn.querySelector('.copy-hint') as HTMLElement;
        const original = hint.textContent;
        hint.textContent = '已复制!';
        hint.style.opacity = '1';
        setTimeout(() => { hint.textContent = original; hint.style.opacity = ''; }, 1500);
      } catch (e) {}
    });
  });
</script>
