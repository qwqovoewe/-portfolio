---
import Layout from '../layouts/Layout.astro';

const milestones = [
  {
    date: '2024.09',
    title: '踏入编程世界',
    description: '开始学习 HTML、CSS 和 JavaScript，完成了第一个静态网页项目。对前端开发产生浓厚兴趣。',
    icon: '🌱',
  },
  {
    date: '2025.03',
    title: '深入前端框架',
    description: '系统学习 React 和 Vue.js，掌握组件化开发思想。开始参与开源社区，提交第一个 PR。',
    icon: '⚡',
  },
  {
    date: '2025.09',
    title: '全栈开发探索',
    description: '学习 Node.js 和数据库技术，完成多个全栈项目。开始关注系统设计和性能优化。',
    icon: '🚀',
  },
  {
    date: '2026.03',
    title: '持续精进',
    description: '深入 TypeScript 和现代工具链，探索 AI 辅助开发。构建个人作品集，持续输出技术博客。',
    icon: '✨',
  },
];
---

<Layout title="时间线 | Portfolio">
  <section class="mx-auto max-w-3xl px-6 py-20">
    <h1 class="text-4xl font-bold tracking-tight mb-2">学习时间线</h1>
    <p class="text-text-muted mb-16">我的成长路径与关键里程碑。</p>

    <div class="relative">
      {/* Vertical line */}
      <div class="absolute left-6 top-0 bottom-0 w-px bg-border"></div>

      <div class="space-y-12">
        {milestones.map((m, i) => (
          <div class="relative pl-16">
            {/* Dot */}
            <div class="absolute left-4 top-1 w-5 h-5 rounded-full border-2 border-accent bg-bg flex items-center justify-center text-xs">
              {m.icon}
            </div>

            <span class="text-xs font-mono text-accent tracking-wider">{m.date}</span>
            <h3 class="text-xl font-semibold mt-1 mb-2">{m.title}</h3>
            <p class="text-text-muted leading-relaxed">{m.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
